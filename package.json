{
  "name": "@manptl553-oss/white-labeled-auth",
  "version": "1.0.13",
  "description": "White-labeled authentication & onboarding SDK. Works across React, Angular, Vue and Vanilla JS.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./sdk": {
      "types": "./dist/sdk/index.d.ts",
      "import": "./dist/sdk/chainit-auth.esm.js",
      "require": "./dist/sdk/chainit-auth.umd.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "browser": {
    "node-fetch": false,
    "encoding": false
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "clean": "rm -rf dist",
    "build": "npm run clean && npm run build:lib && npm run build:sdk && npm run build:types",
    "build:lib": "vite build --mode lib",
    "build:sdk": "vite build --mode sdk",
    "build:types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "preview": "vite preview",
    "prepack": "npm run build",
    "release": "node scripts/release.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "axios": "^1.0.0",
    "@tanstack/react-query": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "axios": {
      "optional": true
    },
    "@tanstack/react-query": {
      "optional": true
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@aws-amplify/ui-react": "^6.15.2",
    "@aws-amplify/ui-react-liveness": "^3.6.3",
    "@eslint/js": "^9.39.1",
    "@idscan/idvc2": "^3.9.2",
    "@prettier/plugin-xml": "^3.4.2",
    "@tanstack/react-query": "^5.90.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "aws-amplify": "^6.0.0",
    "axios": "^1.13.6",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jwt-decode": "^4.0.0",
    "prettier": "^3.8.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.57.0",
    "tsc-alias": "^1.8.16",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "uuid": "^13.0.0",
    "vite": "^7.3.1",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "zod": "^4.3.6"
  },
  "keywords": [
    "authentication",
    "sdk",
    "onboarding",
    "white-label",
    "otp",
    "face-liveness",
    "kyc",
    "identity-verification"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/blackinc/white-labeled-auth.git"
  },
  "homepage": "https://github.com/blackinc/white-labeled-auth#readme",
  "bugs": {
    "url": "https://github.com/blackinc/white-labeled-auth/issues"
  }
}
